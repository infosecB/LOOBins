---
import TacticBadge from './TacticBadge.astro';
import TagBadge from './TagBadge.astro';

interface Props {
  name: string;
  description: string;
  code?: string;
  tactics: string[];
  tags: string[];
}

const { name, description, code, tactics, tags } = Astro.props;
---

<div class="border border-border rounded-lg p-5 bg-surface-light">
  <h3 class="text-lg font-semibold text-text-primary mb-2">{name}</h3>
  <p class="text-text-secondary mb-3">{description}</p>

  {code && (
    <div class="mb-3">
      <pre class="bg-surface rounded-md p-4 overflow-x-auto border border-border"><code class="text-sm text-green-400 font-mono" set:text={code} /></pre>
    </div>
  )}

  <div class="flex flex-wrap gap-1.5">
    {tactics.map((t) => <TacticBadge tactic={t} />)}
    {tags.map((t) => <TagBadge tag={t} />)}
  </div>
</div>
