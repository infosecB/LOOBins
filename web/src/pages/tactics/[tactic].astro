---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LOOBinCard from '../../components/LOOBinCard.astro';
import { getCollection } from 'astro:content';
import { getAllTactics, slugify, loobinHasTactic } from '../../utils/helpers';

export async function getStaticPaths() {
  const loobins = await getCollection('loobins');
  const tactics = getAllTactics(loobins);

  return [...tactics.keys()].map((tactic) => ({
    params: { tactic: slugify(tactic) },
    props: {
      tactic,
      loobins: loobins.filter((l) => loobinHasTactic(l, tactic)),
    },
  }));
}

const { tactic, loobins } = Astro.props;
const sorted = loobins.sort((a: any, b: any) => a.data.name.localeCompare(b.data.name));
---

<BaseLayout title={tactic} description={`LOOBins using the ${tactic} tactic`}>
  <div class="mb-6">
    <a href="/tactics/" class="text-text-secondary hover:text-text-primary text-sm">&larr; All Tactics</a>
  </div>

  <h1 class="text-3xl font-bold mb-2">{tactic}</h1>
  <p class="text-text-secondary mb-6">{sorted.length} binaries with this tactic</p>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {sorted.map((loobin: any) => {
      const tactics = [...new Set(loobin.data.example_use_cases.flatMap((uc: any) => uc.tactics))];
      const tags = [...new Set(loobin.data.example_use_cases.flatMap((uc: any) => uc.tags))];
      return (
        <LOOBinCard
          name={loobin.data.name}
          slug={loobin.id}
          shortDescription={loobin.data.short_description}
          tactics={tactics}
          tags={tags}
        />
      );
    })}
  </div>
</BaseLayout>
