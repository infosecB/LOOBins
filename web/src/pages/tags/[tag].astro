---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LOOBinCard from '../../components/LOOBinCard.astro';
import { getCollection } from 'astro:content';
import { getAllTags, slugify, loobinHasTag } from '../../utils/helpers';

export async function getStaticPaths() {
  const loobins = await getCollection('loobins');
  const tags = getAllTags(loobins);

  return [...tags.keys()].map((tag) => ({
    params: { tag: slugify(tag) },
    props: {
      tag,
      loobins: loobins.filter((l) => loobinHasTag(l, tag)),
    },
  }));
}

const { tag, loobins } = Astro.props;
const sorted = loobins.sort((a: any, b: any) => a.data.name.localeCompare(b.data.name));
---

<BaseLayout title={`Tag: ${tag}`} description={`LOOBins tagged with ${tag}`}>
  <div class="mb-6">
    <a href="/tags/" class="text-text-secondary hover:text-text-primary text-sm">&larr; All Tags</a>
  </div>

  <h1 class="text-3xl font-bold mb-2">{tag}</h1>
  <p class="text-text-secondary mb-6">{sorted.length} binaries with this tag</p>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {sorted.map((loobin: any) => {
      const tactics = [...new Set(loobin.data.example_use_cases.flatMap((uc: any) => uc.tactics))];
      const tags = [...new Set(loobin.data.example_use_cases.flatMap((uc: any) => uc.tags))];
      return (
        <LOOBinCard
          name={loobin.data.name}
          slug={loobin.id}
          shortDescription={loobin.data.short_description}
          tactics={tactics}
          tags={tags}
        />
      );
    })}
  </div>
</BaseLayout>
